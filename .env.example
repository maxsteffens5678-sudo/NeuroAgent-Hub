# ============================================
# NeuroAgent Hub Configuration
# Environment Variables Template
# ============================================

# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development
HOST=localhost

# ============================================
# API KEYS & EXTERNAL SERVICES
# ============================================

# Google Custom Search API (Optional - for advanced research)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# OpenWeather API (Optional - for context-aware responses)
OPENWEATHER_API_KEY=your_openweather_key_here

# News API (Optional - for latest information)
NEWS_API_KEY=your_newsapi_key_here

# ============================================
# DATABASE CONFIGURATION (Optional)
# ============================================

# MongoDB (if you want persistent storage)
MONGODB_URI=mongodb://localhost:27017/neuroagent
MONGODB_USER=admin
MONGODB_PASSWORD=your_password_here

# ============================================
# OLLAMA LOCAL AI CONFIGURATION
# ============================================

# Ollama Server URL (for local AI models)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Available Ollama Models:
# - mistral (7B, fast & good)
# - neural-chat (7B, conversational)
# - dolphin-mixtral (8x7B, powerful)
# - llama2 (7B-70B, general purpose)
# - codellama (7B-34B, code generation)
# - orca-mini (3B, lightweight)

# ============================================
# MEMORY & LEARNING CONFIGURATION
# ============================================

# Enable Self-Learning System
ENABLE_LEARNING=true
ENABLE_MEMORY_PERSISTENCE=true
MEMORY_FILE_PATH=./memory.json

# Memory Settings
MAX_MEMORIES=1000
MEMORY_RETENTION_DAYS=90
AUTO_CLEANUP_MEMORY=true

# Learning Rate (0.0 - 1.0)
LEARNING_RATE=0.7

# ============================================
# RESEARCH AGENT CONFIGURATION
# ============================================

# Research Depth: shallow | medium | deep
RESEARCH_DEPTH=deep

# Maximum research sources per query
MAX_RESEARCH_SOURCES=5

# Enable multi-source research
ENABLE_MULTI_SOURCE_RESEARCH=true

# Research timeout (milliseconds)
RESEARCH_TIMEOUT=30000

# ============================================
# CODE GENERATION CONFIGURATION
# ============================================

# Code Generation Language: javascript | python | java | go | rust | cpp
DEFAULT_CODE_LANGUAGE=javascript

# Enable code optimization suggestions
ENABLE_CODE_OPTIMIZATION=true

# Enable security analysis for generated code
ENABLE_SECURITY_ANALYSIS=true

# ============================================
# AGENT CONFIGURATION
# ============================================

# Enable specific agents
ENABLE_RESEARCH_AGENT=true
ENABLE_CODEGEN_AGENT=true
ENABLE_OPTIMIZER_AGENT=true
ENABLE_LEARNER_AGENT=true
ENABLE_REFLECTOR_AGENT=true
ENABLE_SELFIMPROVER_AGENT=true
ENABLE_FEEDBACK_AGENT=true

# Agent Response Timeout (milliseconds)
AGENT_TIMEOUT=60000

# Enable agent statistics tracking
ENABLE_AGENT_STATISTICS=true

# ============================================
# SECURITY CONFIGURATION
# ============================================

# CORS Settings
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
CORS_METHODS=GET,POST,PUT,DELETE
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable security headers
ENABLE_SECURITY_HEADERS=true

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Level: debug | info | warn | error
LOG_LEVEL=info

# Enable file logging
ENABLE_FILE_LOGGING=true
LOG_FILE_PATH=./logs/app.log

# Maximum log file size (MB)
MAX_LOG_FILE_SIZE=50

# Enable colored console output
ENABLE_COLORED_LOGS=true

# ============================================
# PERFORMANCE CONFIGURATION
# ============================================

# Worker Threads (for CPU-intensive tasks)
WORKER_THREADS=4

# Cache Configuration
ENABLE_CACHING=true
CACHE_TTL_MS=3600000
CACHE_MAX_SIZE=100

# Memory Limits (MB)
MAX_MEMORY_USAGE=1024
MEMORY_WARNING_THRESHOLD=800

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Deployment environment: development | staging | production
DEPLOYMENT_ENV=development

# Enable maintenance mode
MAINTENANCE_MODE=false

# API Version
API_VERSION=v1

# Application Name
APP_NAME=NeuroAgent-Hub

# Application Version
APP_VERSION=1.0.0

# ============================================
# EXTERNAL INTEGRATIONS
# ============================================

# GitHub Integration (Optional)
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_username

# Discord Webhook (Optional - for notifications)
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/your_webhook_id

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your_webhook_url

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/Disable Features
FEATURE_PWA_MODE=true
FEATURE_OFFLINE_MODE=true
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_BACKGROUND_SYNC=false
FEATURE_VOICE_INPUT=false
FEATURE_DARK_MODE=true

# Beta Features
BETA_ADVANCED_RESEARCH=false
BETA_AI_CODE_REVIEW=false
BETA_PREDICTIVE_SUGGESTIONS=false

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Enable analytics tracking
ENABLE_ANALYTICS=false

# Sentry Error Tracking (Optional)
SENTRY_DSN=your_sentry_dsn_here

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# ============================================
# MOBILE OPTIMIZATION
# ============================================

# Optimize for mobile devices
MOBILE_OPTIMIZATION=true

# Screen size breakpoints
MOBILE_BREAKPOINT=768
TABLET_BREAKPOINT=1024

# Touch-friendly UI
ENABLE_TOUCH_OPTIMIZATION=true

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable detailed error messages
DEBUG_MODE=false

# Enable hot reloading
ENABLE_HOT_RELOAD=true

# Suppress warnings
SUPPRESS_WARNINGS=false

# Test mode
TEST_MODE=false

# ============================================
# NOTES
# ============================================

# HOW TO USE:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. Never commit .env to version control
# 4. Add .env to .gitignore

# IMPORTANT:
# - Keep your API keys secret!
# - Don't share your .env file
# - Use different keys for different environments
# - Rotate keys regularly
# - Monitor API usage

# DEPLOYMENT HINTS:
# - For Heroku: Set config vars in dashboard
# - For Railway: Set variables in project settings
# - For Vercel: Add to Environment Variables
# - For Docker: Pass with --env-file flag
# - For local: Create .env file in root directory
